{
  "name": "school-booking",
  "private": true,
  "workspaces": ["apps/*"],
  "scripts": {
    "dev":        "concurrently -n backend,frontend -c cyan,magenta \"npm run dev -w apps/backend\" \"npm run dev -w apps/frontend\"",
    "dev:backend":    "npm run dev -w apps/backend",
    "dev:frontend":   "npm run dev -w apps/frontend",
    "infra:up":   "docker compose up -d",
    "infra:down": "docker compose down",
    "db:migrate": "npm run migrate -w apps/backend",
    "db:studio":  "npm run studio -w apps/backend",
    "build":      "npm run build -w apps/frontend"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  }
}
