generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model School {
  id               String   @id @default(cuid())
  name             String
  address          String?
  contactEmail     String
  subscriptionPlan String   @default("FREE")
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())

  teachers Teacher[]
  events   Event[]
}

model Teacher {
  id              String   @id @default(cuid())
  schoolId        String
  keycloakUserId  String   @unique
  name            String
  email           String
  subject         String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())

  school School @relation(fields: [schoolId], references: [id])
  slots  Slot[]
}

model Event {
  id           String   @id @default(cuid())
  schoolId     String
  title        String
  description  String?
  eventType    String
  startDate    DateTime
  endDate      DateTime
  location     String?
  maxCapacity  Int?
  qrCodeUrl    String?
  qrToken      String   @unique @default(cuid())
  createdBy    String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())

  school   School    @relation(fields: [schoolId], references: [id])
  slots    Slot[]
  bookings Booking[]
}

model Slot {
  id              String   @id @default(cuid())
  eventId         String
  teacherId       String?
  startTime       DateTime
  endTime         DateTime
  maxBookings     Int      @default(1)
  currentBookings Int      @default(0)
  isActive        Boolean  @default(true)

  event    Event    @relation(fields: [eventId], references: [id])
  teacher  Teacher? @relation(fields: [teacherId], references: [id])
  bookings Booking[]
}

model Booking {
  id          String    @id @default(cuid())
  eventId     String
  slotId      String?
  parentEmail String
  childName   String?
  status      String    @default("CONFIRMED")
  cancelToken String    @unique @default(uuid())
  bookedAt    DateTime  @default(now())
  modifiedAt  DateTime?

  event Event  @relation(fields: [eventId], references: [id])
  slot  Slot?  @relation(fields: [slotId], references: [id])
}